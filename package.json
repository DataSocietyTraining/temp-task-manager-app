{
  "name": "task-manager-copilot-starter",
  "version": "1.0.0",
  "private": true,
  "description": "Lean Copilot starter for implementing the Task Manager API from a working reference app.",
  "scripts": {
    "dev:backend": "pnpm --filter backend dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "test": "pnpm --filter tests test",
    "build:backend": "pnpm --filter backend build",
    "build:frontend": "pnpm --filter frontend build",
    "check": "pnpm -r exec tsc --noEmit --pretty false"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
